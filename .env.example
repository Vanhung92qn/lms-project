# -----------------------------------------------------------------------------
# AI-LMS environment template — copy to .env for local dev.
# Never commit .env; secrets here are placeholders only.
# -----------------------------------------------------------------------------

# App environment
NODE_ENV=development
PORT_API=4000
PORT_WEB=3000

# Public base URL the web app uses to reach api-core. NEXT_PUBLIC_* vars are
# baked into the JS bundle at `next build` time, so both dev and prod must
# rebuild the web app when this changes.
#   dev:  http://localhost:4000/api/v1
#   prod: https://khohoc.online/api/v1   ← use this on the VPS
NEXT_PUBLIC_API_URL=https://khohoc.online/api/v1
NEXT_PUBLIC_APP_NAME=AI-LMS
NEXT_PUBLIC_APP_DOMAIN=khohoc.online

# Postgres — matches docker-compose.yml
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lms
POSTGRES_USER=lms
POSTGRES_PASSWORD=change-me-in-prod
DATABASE_URL=postgresql://lms:change-me-in-prod@localhost:5432/lms?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=dev-access-secret-change-me-32bytes-minimum!!!
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-32bytes-minimum!!!
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Public URL the API is reachable at from the outside world (used to build
# OAuth redirect URIs + the fragment redirect back to the web app).
#   dev:  http://localhost:4000
#   prod: https://khohoc.online
PUBLIC_API_BASE_URL=https://khohoc.online

# CORS — comma-separated allow-list of web origins that may hit the API with
# credentials.
#   dev:  http://localhost:3000
#   prod: https://khohoc.online,http://localhost:3000
CORS_ORIGIN=https://khohoc.online,http://localhost:3000

# Sandbox-orchestrator — where api-core POSTs source code for grading.
# In dev it runs on 127.0.0.1:5001 via a Python venv; in prod it's a
# containerised service on the internal network.
SANDBOX_URL=http://127.0.0.1:5001

# ai-gateway — where api-core proxies AI Tutor SSE streams. The gateway
# fans requests out to Ollama (free tier) or DeepSeek (paid tier) based
# on the `provider` field api-core resolves per request. Runs on
# 127.0.0.1:5002 via a Python venv; Ollama itself listens on
# 127.0.0.1:11434 inside the lms-ollama container.
AI_GATEWAY_URL=http://127.0.0.1:5002

# DeepSeek — the paid-tier backend. Used for:
#   - teachers on their own courses (200 req/day cap)
#   - students enrolled in a paid course they've purchased (200 req/day cap)
#   - admin accounts (200 req/day cap)
# Leave DEEPSEEK_API_KEY empty to disable the paid tier — every request
# falls back to Llama automatically. Sign up + get key at
# https://platform.deepseek.com. Model `deepseek-chat` is the generalist
# model; `deepseek-coder` is code-specialised but slightly more expensive.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OAuth — leave empty if the corresponding provider is not yet configured.
# The buttons on the web app will surface "oauth_not_configured" errors when
# clicked against an empty provider.
# Setup instructions: docs/runbook/oauth-setup.md
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# i18n
DEFAULT_LOCALE=vi
SUPPORTED_LOCALES=vi,en
