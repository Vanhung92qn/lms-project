# apps/web/.env.example
#
# Copy to `.env.local` (gitignored) and edit for your environment.
#
# WHY THIS FILE EXISTS — Next.js reads `.env*` files from THIS directory
# (apps/web/), not from the monorepo root. The monorepo-root .env drives
# api-core runtime; this one drives the web build.
#
# `NEXT_PUBLIC_*` values are baked into the JS bundle at `next build` time.
# Changing them requires rebuilding the web app:
#   cd apps/web && rm -rf .next && pnpm exec next build
#
# Precedence (later overrides earlier):
#   .env.production.local  → loaded on prod builds only, gitignored
#   .env.local             → loaded on every environment, gitignored ← most common
#   .env.production        → loaded on prod builds only
#   .env                   → baseline, checked in (if present) — we don't use this file
#
# See: https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# Public base URL the web app calls to reach api-core.
#   dev:  http://localhost:4000/api/v1
#   prod: https://khohoc.online/api/v1
NEXT_PUBLIC_API_URL=https://khohoc.online/api/v1

NEXT_PUBLIC_APP_NAME=AI-LMS
NEXT_PUBLIC_APP_DOMAIN=khohoc.online
