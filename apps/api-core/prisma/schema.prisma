// AI-LMS — Prisma schema
// P1 scope: IAM (users, roles, refresh tokens) + audit log.
// Later phases extend this schema with catalog, learning, billing,
// and knowledge-graph tables. See docs/architecture/data-model.md.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext, pgcrypto, vector]
}

// -----------------------------------------------------------------------------
// IAM
// -----------------------------------------------------------------------------

enum UserStatus {
  active
  locked
  pending
}

enum RoleName {
  student
  teacher
  admin
  ai_engine
}

model User {
  id                  String     @id @default(uuid()) @db.Uuid
  email               String     @unique @db.Citext
  passwordHash        String     @map("password_hash")
  displayName         String     @map("display_name")
  avatarUrl           String?    @map("avatar_url")
  locale              String     @default("vi")
  status              UserStatus @default(active)
  // Denormalised wallet balance (VND cents). Source of truth — any write
  // must happen inside the same transaction as a WalletTopup.approve or
  // Entitlement.purchase so we never drift.
  walletBalanceCents  Int        @default(0) @map("wallet_balance_cents")
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  userRoles          UserRole[]
  refreshTokens      RefreshToken[]
  auditLogs          AuditLog[]
  oauthAccounts      OAuthAccount[]
  coursesTaught      Course[]       @relation("CoursesTaught")
  enrollments        Enrollment[]
  submissions        Submission[]
  mastery            UserMastery[]
  walletTopups       WalletTopup[]  @relation("UserTopups")
  approvedTopups     WalletTopup[]  @relation("AdminApprovedTopups")
  entitlements       Entitlement[]

  @@index([status])
  @@map("users")
}

model OAuthAccount {
  id         String   @id @default(uuid()) @db.Uuid
  provider   String   // 'google' | 'github' — kept as string to avoid a migration on every new provider
  providerId String   @map("provider_id")
  userId     String   @map("user_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
  @@map("oauth_accounts")
}

// -----------------------------------------------------------------------------
// Catalog / CMS
// Courses are owned by a teacher; drafts are private, published courses land
// in the public catalog. Modules order lessons within a course; lessons carry
// markdown (theory), an exercise (code task), or a quiz (P5).
// -----------------------------------------------------------------------------

enum CourseStatus {
  draft
  published
  archived
}

enum PricingModel {
  free
  paid
}

enum LessonType {
  markdown
  exercise
  quiz
}

enum CodeLanguage {
  c
  cpp
  js
  python
}

model Course {
  id            String        @id @default(uuid()) @db.Uuid
  slug          String        @unique
  title         String
  description   String?
  teacherId     String        @map("teacher_id") @db.Uuid
  status        CourseStatus  @default(draft)
  pricingModel  PricingModel  @default(free) @map("pricing_model")
  priceCents    Int?          @map("price_cents")
  currency      String?       @db.Char(3)
  coverUrl      String?       @map("cover_url")
  locale        String        @default("vi")
  publishedAt   DateTime?     @map("published_at") @db.Timestamptz(6)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  teacher       User          @relation("CoursesTaught", fields: [teacherId], references: [id])
  modules       Module[]
  enrollments   Enrollment[]
  entitlements  Entitlement[]

  @@index([status, publishedAt])
  @@index([teacherId])
  @@map("courses")
}

model Module {
  id         String   @id @default(uuid()) @db.Uuid
  courseId   String   @map("course_id") @db.Uuid
  title      String
  sortOrder  Int      @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons    Lesson[]

  @@unique([courseId, sortOrder])
  @@index([courseId])
  @@map("modules")
}

model Lesson {
  id              String     @id @default(uuid()) @db.Uuid
  moduleId        String     @map("module_id") @db.Uuid
  title           String
  sortOrder       Int        @map("sort_order")
  type            LessonType
  contentMarkdown String?    @map("content_markdown") @db.Text
  estMinutes      Int?       @map("est_minutes")
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  module          Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  exercise        Exercise?
  knowledgeTags   LessonKnowledgeNode[]

  @@unique([moduleId, sortOrder])
  @@index([moduleId])
  @@map("lessons")
}

model Exercise {
  id             String       @id @default(uuid()) @db.Uuid
  lessonId       String       @unique @map("lesson_id") @db.Uuid
  language       CodeLanguage
  starterCode    String?      @map("starter_code") @db.Text
  solutionCode   String?      @map("solution_code") @db.Text
  memoryLimitMb  Int          @default(128) @map("memory_limit_mb")
  timeLimitMs    Int          @default(3000) @map("time_limit_ms")

  lesson         Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  testCases      TestCase[]
  submissions    Submission[]

  @@map("exercises")
}

model TestCase {
  id             String   @id @default(uuid()) @db.Uuid
  exerciseId     String   @map("exercise_id") @db.Uuid
  input          String?  @db.Text
  expectedOutput String?  @map("expected_output") @db.Text
  isSample       Boolean  @default(false) @map("is_sample")
  weight         Int      @default(1)

  exercise       Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  results        SubmissionTestResult[]

  @@index([exerciseId])
  @@map("test_cases")
}

// -----------------------------------------------------------------------------
// Assessment — students POST code → sandbox-orchestrator executes → verdict
// lands here. One Submission per attempt; one SubmissionTestResult per test
// case the submission was evaluated against.
// -----------------------------------------------------------------------------

enum Verdict {
  pending
  ac      // accepted
  wa      // wrong answer
  tle     // time-limit exceeded
  mle     // memory-limit exceeded
  ce      // compile error
  re      // runtime error
  ie      // internal error (orchestrator failure)
}

model Submission {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  exerciseId  String       @map("exercise_id") @db.Uuid
  sourceCode  String       @map("source_code") @db.Text
  language    CodeLanguage
  verdict     Verdict      @default(pending)
  runtimeMs   Int?         @map("runtime_ms")
  memoryKb    Int?         @map("memory_kb")
  stderr      String?      @db.Text
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  finishedAt  DateTime?    @map("finished_at") @db.Timestamptz(6)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise    Exercise     @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  results     SubmissionTestResult[]

  @@index([userId, exerciseId, createdAt])
  @@index([exerciseId, verdict])
  @@map("submissions")
}

model SubmissionTestResult {
  submissionId String   @map("submission_id") @db.Uuid
  testCaseId   String   @map("test_case_id") @db.Uuid
  passed       Boolean
  verdict      Verdict  @default(pending)
  actualOutput String?  @map("actual_output") @db.Text
  runtimeMs    Int?     @map("runtime_ms")

  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  testCase     TestCase   @relation(fields: [testCaseId], references: [id])

  @@id([submissionId, testCaseId])
  @@index([submissionId])
  @@map("submission_test_results")
}

// -----------------------------------------------------------------------------
// Learning — enrollment binds a user to a course; progress_pct is a
// denormalised cache that gets updated on submission / lesson-complete events
// (lands in P3 / P5). MVP treats enrollment as free for any published course.
// -----------------------------------------------------------------------------

model Enrollment {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  courseId     String   @map("course_id") @db.Uuid
  enrolledAt   DateTime @default(now()) @map("enrolled_at") @db.Timestamptz(6)
  progressPct  Decimal  @default(0) @map("progress_pct") @db.Decimal(5, 2)

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("enrollments")
}

// -----------------------------------------------------------------------------
// Billing v1 (P6) — wallet-based manual top-up.
//
// Flow:
//   1. Student requests a top-up: chooses amount + method, receives a
//      unique `referenceCode` (e.g. TOPUP-A3F9C1) that becomes the bank
//      transfer note. WalletTopup row lands as `pending`.
//   2. Student transfers via MoMo / VietQR using that reference.
//   3. Admin sees pending list in /studio/topups, verifies the real
//      transfer, clicks Approve → `users.wallet_balance_cents += amount`
//      inside the same tx as the status flip. Rejected → no balance change.
//   4. Student buys any paid course — one-click deduct from wallet,
//      creates `Entitlement` + `Enrollment`, zero admin involvement.
//
// Decoupling top-up from course purchase means admin reviews money, not
// access; any student with sufficient balance can buy any course instantly.
// -----------------------------------------------------------------------------

enum TopupMethod {
  momo
  bank
}

enum TopupStatus {
  pending
  approved
  rejected
  cancelled
}

model WalletTopup {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  amountCents     Int          @map("amount_cents")
  currency        String       @default("VND") @db.Char(3)
  method          TopupMethod
  status          TopupStatus  @default(pending)
  // Human-readable short code the student uses as the bank transfer
  // memo. Must be globally unique so admins can match a pending row
  // from just the memo field.
  referenceCode   String       @unique @map("reference_code")
  userNote        String?      @map("user_note") @db.Text
  adminNote       String?      @map("admin_note") @db.Text
  approvedById    String?      @map("approved_by_id") @db.Uuid
  approvedAt      DateTime?    @map("approved_at") @db.Timestamptz(6)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  user            User         @relation("UserTopups", fields: [userId], references: [id], onDelete: Cascade)
  approvedBy      User?        @relation("AdminApprovedTopups", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("wallet_topups")
}

enum EntitlementSource {
  purchase
  granted
  free
}

model Entitlement {
  id            String             @id @default(uuid()) @db.Uuid
  userId        String             @map("user_id") @db.Uuid
  courseId      String             @map("course_id") @db.Uuid
  source        EntitlementSource
  // Snapshot of what the student paid at the moment of purchase.
  // Decoupled from Course.priceCents so later price changes don't
  // retro-affect the audit trail.
  amountCents   Int                @default(0) @map("amount_cents")
  grantedAt     DateTime           @default(now()) @map("granted_at") @db.Timestamptz(6)
  expiresAt     DateTime?          @map("expires_at") @db.Timestamptz(6)
  revokedAt     DateTime?          @map("revoked_at") @db.Timestamptz(6)

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  course        Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("entitlements")
}

model Role {
  id        Int        @id @default(autoincrement()) @db.SmallInt
  name      RoleName   @unique
  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId Int    @map("role_id") @db.SmallInt
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @map("token_hash")       // argon2id(opaque token)
  familyId   String    @map("family_id") @db.Uuid
  issuedAt   DateTime  @default(now()) @map("issued_at") @db.Timestamptz(6)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  userAgent  String?   @map("user_agent")
  ip         String?

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// -----------------------------------------------------------------------------
// Knowledge Graph v1 (P5b) — concept-level skill model.
// `knowledge_nodes` is the vocabulary of concepts (e.g. "pointer", "recursion").
// `knowledge_edges` captures prerequisite or sibling relations between nodes.
// `lesson_knowledge_nodes` tags each lesson with 1–3 concepts (many-to-many).
// `user_mastery` stores the per-user BKT score computed by the data-science
// service after each AC submission. The scoring algorithm lives in Python;
// this table is just the write sink the Node backend reads for the dashboard.
// -----------------------------------------------------------------------------

enum KnowledgeRelation {
  prereq
  related
}

model KnowledgeNode {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  title     String
  domain    String   // 'cpp' | 'algo' | 'ds' | 'web' | …
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  outgoingEdges KnowledgeEdge[]       @relation("KnowledgeEdgeFrom")
  incomingEdges KnowledgeEdge[]       @relation("KnowledgeEdgeTo")
  lessonTags    LessonKnowledgeNode[]
  masteryRows   UserMastery[]

  @@index([domain])
  @@map("knowledge_nodes")
}

model KnowledgeEdge {
  id       String            @id @default(uuid()) @db.Uuid
  fromId   String            @map("from_id") @db.Uuid
  toId     String            @map("to_id") @db.Uuid
  weight   Decimal           @default(1.0) @db.Decimal(4, 3)
  relation KnowledgeRelation @default(prereq)

  from KnowledgeNode @relation("KnowledgeEdgeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   KnowledgeNode @relation("KnowledgeEdgeTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId, relation])
  @@index([toId])
  @@map("knowledge_edges")
}

model LessonKnowledgeNode {
  lessonId String @map("lesson_id") @db.Uuid
  nodeId   String @map("node_id") @db.Uuid

  lesson Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  node   KnowledgeNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@id([lessonId, nodeId])
  @@index([nodeId])
  @@map("lesson_knowledge_nodes")
}

model UserMastery {
  userId        String   @map("user_id") @db.Uuid
  nodeId        String   @map("node_id") @db.Uuid
  score         Decimal  @default(0.1) @db.Decimal(4, 3) // 0.000 → 1.000
  confidence    Decimal  @default(0) @db.Decimal(4, 3)
  attempts      Int      @default(0)
  lastUpdatedAt DateTime @default(now()) @map("last_updated_at") @db.Timestamptz(6)

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  node KnowledgeNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@id([userId, nodeId])
  @@index([userId, score])
  @@map("user_mastery")
}

// -----------------------------------------------------------------------------
// Audit (append-only security events)
// -----------------------------------------------------------------------------

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  userId     String?  @map("user_id") @db.Uuid
  event      String
  ip         String?
  userAgent  String?  @map("user_agent")
  metadata   Json?    @db.JsonB
  occurredAt DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt])
  @@index([event, occurredAt])
  @@map("audit_log")
}
